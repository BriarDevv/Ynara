# Monorepo pnpm + builds nativos de Expo/React Native.
# node-linker=hoisted aplana node_modules (sin symlinks aislados) para que el
# autolinking nativo de RN resuelva los módulos (reanimated/worklets, expo-*)
# y no queden duplicados de módulos nativos en el dev build / EAS build.
# Requerido desde el primer dev build de apps/mobile (F3, fondo vivo con Skia).
node-linker=hoisted
