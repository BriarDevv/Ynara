# apps/web — Variables de entorno

# URL pública del backend (FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Auth.js v5
AUTH_SECRET=cambiar-en-produccion
NEXTAUTH_URL=http://localhost:3000

# TODO: agregar credenciales de proveedores OAuth si se usan (Google,
# Apple). Tener cuidado: las credenciales van en variables del
# servidor, NUNCA en NEXT_PUBLIC_*.

# Telemetría (opcional)
NEXT_PUBLIC_POSTHOG_KEY=

# Sentry (opcional)
NEXT_PUBLIC_SENTRY_DSN=

# Recordatorio: prohibido configurar @supabase/supabase-js desde el
# frontend (regla #5 de AGENTS.md). Todo acceso a datos va por
# NEXT_PUBLIC_API_URL.
