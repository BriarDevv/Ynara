# apps/web — Variables de entorno
#
# Validadas por Zod en `src/lib/env.ts`. Si NEXT_PUBLIC_API_URL no es
# una URL válida, el módulo throw-ea en import time (fail-fast). Esto
# es intencional: queremos errores tempranos en build/runtime antes que
# silenciosamente apuntar al lugar incorrecto.

# URL pública del backend (FastAPI). Debe ser una URL absoluta válida.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Mocks (MSW) — flag-driven, default OFF. Sólo se evalúan si NODE_ENV !==
# "production". Sin este flag, `pnpm dev` pega al backend real
# (NEXT_PUBLIC_API_URL). Los mocks son OPT-IN para offline-first / pruebas:
# prendelos con =true. En production están **siempre off** sin importar el flag.
NEXT_PUBLIC_ENABLE_MOCKS=false

# Auth.js v5
AUTH_SECRET=cambiar-en-produccion
NEXTAUTH_URL=http://localhost:3000

# TODO: agregar credenciales de proveedores OAuth si se usan (Google,
# Apple). Tener cuidado: las credenciales van en variables del
# servidor, NUNCA en NEXT_PUBLIC_*.

# Telemetría (opcional)
NEXT_PUBLIC_POSTHOG_KEY=

# Sentry (opcional)
NEXT_PUBLIC_SENTRY_DSN=

# Recordatorio: prohibido configurar @supabase/supabase-js desde el
# frontend (regla #5 de AGENTS.md). Todo acceso a datos va por
# NEXT_PUBLIC_API_URL.
