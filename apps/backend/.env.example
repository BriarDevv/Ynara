# Base de datos (Fase MVP: Supabase como Postgres gestionado)
# En V2 se cambia este connection string al Postgres self-hosted
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Pool de conexiones (Supabase recomienda 15 max para free tier)
DATABASE_POOL_SIZE=10

# DB dedicada para los tests de integracion (NUNCA prod). Postgres con
# pgvector >= 0.5.0. Sin esto, los tests `-m integration` se SKIPean.
# TEST_DATABASE_URL=postgresql://postgres:test@localhost:5433/ynara_test

# Redis (Upstash free tier o local en Docker)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# Serving LLM (vLLM corriendo en la 4080 Super, ADR-009)
# base_url OpenAI-compatible de cada proceso vLLM. served_name, parsers
# y quantization viven en ynara.config.json, no aca.
LLM_PRIMARY_BASE_URL=http://localhost:8001/v1
LLM_SECONDARY_BASE_URL=http://localhost:8002/v1
# Topologia de serving: split_process (2 procesos) | single_process | swap_lru
LLM_TOPOLOGY=split_process

# Embeddings (ADR-008: bge-m3, 1024-dim, on-prem)
EMBEDDING_MODEL=bge-m3

# Cifrado de memoria a nivel campo (ADR-007 D3). GENERAR con:
#   openssl rand -base64 32
# y guardar en el gestor de secretos del equipo. NUNCA commitear (regla #2).
# Lo usan los wrappers de memoria (PR C); sin esto el crypto no arranca.
MEMORY_ENCRYPTION_MASTER_KEY=

# Auth
JWT_SECRET=cambiar-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ynara-uploads

# Observabilidad
# Sentry: vacio => deshabilitado (no se manda nada a ningun lado). Con DSN, el
# before_send limpia PII antes de transmitir (regla #4). traces 0.0 = sin tracing.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
POSTHOG_KEY=

# Environment
ENVIRONMENT=development
