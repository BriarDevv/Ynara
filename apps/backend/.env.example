# ===========================================================================
# Base de datos: DEV vs PROD  (leer "Base de datos: dev vs prod" en README.md)
# ===========================================================================
# Hay UN solo DATABASE_URL activo. Elegí UNA de las dos opciones de abajo.
#
# --- OPCION A · DEV LOCAL (default SEGURO, recomendado para desarrollo) -----
# Postgres local con pgvector. Reusa el contenedor de tests (:5433) creando
# una DB `ynara_dev` (ver README, comando `createdb`/SQL). El guard anti-prod
# del arranque (app/main.py) NO se dispara con un host local.
DATABASE_URL=postgresql://postgres:test@localhost:5433/ynara_dev
#
# --- OPCION B · PROD (Supabase, INTENCIONAL) -------------------------------
# Comentá la OPCION A y descomentá esta SOLO si querés apuntar a la DB de prod.
# OJO: correrla en dev (sin ENVIRONMENT=production) requiere ademas el opt-in
# explícito YNARA_ALLOW_PROD_DB=1 (ver más abajo); de lo contrario el guard
# aborta el arranque. En el deploy real va ENVIRONMENT=production.
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Pool de conexiones (Supabase recomienda 15 max para free tier)
DATABASE_POOL_SIZE=10

# Guard anti-prod (opt-in): por default la app se NIEGA a bootear en modo NO
# producción contra un host de DB de prod conocido (*.supabase.co / .supabase.com
# / pooler.supabase) — fue un incidente real (usuario creado/borrado en prod).
# Poné YNARA_ALLOW_PROD_DB=1 SOLO para una corrida dev-contra-prod consciente.
# En production (ENVIRONMENT=production) el guard nunca aplica.
# YNARA_ALLOW_PROD_DB=1

# DB dedicada para los tests de integracion (NUNCA prod). Postgres con
# pgvector >= 0.5.0. Sin esto, los tests `-m integration` se SKIPean.
# TEST_DATABASE_URL=postgresql://postgres:test@localhost:5433/ynara_test

# Redis (Upstash free tier o local en Docker)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# Serving LLM (Ollama en 16 GB / vLLM en 24 GB+, ADR-013 + ADR-014)
# LLM_SERVING: lista JSON (una linea) de endpoints de serving. Cada entrada =
# UN endpoint: {"base_url": <endpoint OpenAI-compatible>, "models": [<served_names>]}.
# served_name, parsers y quantization viven en ynara.config.json, no aca (ADR-009 D4).
# La lista ES la topologia (ADR-013): N entradas = N endpoints; varias entradas con el
# MISMO served_name = N instancias del mismo modelo (escalado, ADR-009 §4). Cada client
# anuncia SOLO sus models -> el pool rutea cada modelo al endpoint correcto (fix #206).
#
# Default (motor local 16GB, ADR-014): UN endpoint Ollama que sirve TODOS los modelos
# (gemma4 + qwen) en la misma GPU. Un solo proceso, sin fallback on-prem.
LLM_SERVING=[{"base_url":"http://localhost:11434/v1","models":["gemma4","qwen"]}]
# vLLM dual (24GB+, ADR-014): 2 procesos vLLM, un modelo por proceso. El primero es
# el primario; el resto, fallback on-prem. Descomentar esta y comentar la de arriba.
# LLM_SERVING=[{"base_url":"http://localhost:8001/v1","models":["gemma4"]},{"base_url":"http://localhost:8002/v1","models":["qwen"]}]
# Backend de inferencia LLM: 'fake' (determinista, sin GPU — default dev/test) o
# 'vllm' (clientes HTTP reales contra los base_url de LLM_SERVING). El valor 'vllm'
# es un nombre legacy del cliente OpenAI-compatible: NO implica vLLM, sirve igual
# para el motor local 16GB (Ollama/GGUF, ADR-014) o vLLM en 24GB+. En production el
# serving real se fuerza igual; este flag lo prende en dev sin tocar ENVIRONMENT.
LLM_BACKEND=fake

# Embeddings (ADR-008: bge-m3, 1024-dim, on-prem)
EMBEDDING_MODEL=bge-m3
# Backend de embeddings: 'fake' (determinista, sin GPU — default para dev/tests)
# o 'vllm' (servidor real de bge-m3, ADR-009). base_url OpenAI-compatible
# (/v1/embeddings) cuando backend=vllm.
EMBEDDING_BACKEND=fake
EMBEDDING_BASE_URL=http://localhost:8003/v1
# Timeout por request del embedder (segundos), solo backend 'vllm'.
EMBEDDING_TIMEOUT_S=30

# Reranker / cross-encoder (ADR-008: palanca de re-ranking sobre el top-K ANN).
# 'fake' (passthrough determinista, default) o 'vllm' (API /rerank de vLLM).
# Ollama NO sirve cross-encoders: en dev dejar 'fake'. Modelo companion de bge-m3.
RERANKER_BACKEND=fake
RERANKER_BASE_URL=http://localhost:8004/v1
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_TIMEOUT_S=30

# Cifrado de memoria a nivel campo (ADR-007 D3). GENERAR con:
#   openssl rand -base64 32
# y guardar en el gestor de secretos del equipo. NUNCA commitear (regla #2).
# Lo usan los wrappers de memoria (PR C); sin esto el crypto no arranca.
MEMORY_ENCRYPTION_MASTER_KEY=

# Auth
JWT_SECRET=cambiar-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
# Refresh token (issue #63): TTL en minutos, mayor que el access (30 dias).
JWT_REFRESH_EXPIRE_MINUTES=43200
# Ventana de gracia para retry-safe de /auth/refresh (item 1 de #142), en segundos.
# Dentro de ella un reenvio del MISMO refresh recien rotado es un retry benigno
# (no revoca la familia); fuera de ella es replay/robo (revoca la familia).
AUTH_REFRESH_REUSE_GRACE_SECONDS=30
# Rate-limit / lockout del login (issue #63). Estado solo en Redis (sin tablas).
# fail-OPEN: si Redis cae, el login procede sin freno (baseline pre-#63).
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=900
# Rate-limit del register, por IP (mas laxo).
AUTH_REGISTER_MAX_ATTEMPTS=10
AUTH_REGISTER_WINDOW_SECONDS=3600
# Rate-limit de /auth/refresh, por (ip, sub). Mas permisivo que el login (la
# rotacion legitima es frecuente). fail-OPEN si Redis cae.
AUTH_REFRESH_MAX_ATTEMPTS=30
AUTH_REFRESH_WINDOW_SECONDS=900
# Rate-limit de /chat y /chat/stream, por user_id (decenas por minuto). fail-OPEN.
CHAT_MAX_REQUESTS=60
CHAT_WINDOW_SECONDS=60
# Rate-limit de GET /v1/memory/export, por user_id. El endpoint mas caro (descifra
# 3 capas sin paginar): pocas por hora. fail-OPEN si Redis cae.
MEMORY_EXPORT_MAX_REQUESTS=5
MEMORY_EXPORT_WINDOW_SECONDS=3600
# Rate-limit de /v1/sessions (list/get/close), por user_id. UN bucket compartido por
# las 3 rutas (lecturas/ops baratas): default amplio. fail-OPEN si Redis cae.
SESSIONS_MAX_REQUESTS=120
SESSIONS_WINDOW_SECONDS=60

# Reverse-proxy / IP real del cliente (issue #151). El rate-limit anti-fuerza-bruta
# cuenta por IP; detras de Cloudflare Tunnel el peer que ve uvicorn es el conector
# cloudflared (todos los clientes colapsan a una IP) y el freno por IP se neutraliza.
# TRUSTED_PROXY_IPS: IPs/CIDRs de proxies confiables (separa varias con comas, p.ej.
# 127.0.0.1,10.0.0.0/8); en prod detras de Cloudflare Tunnel = la IP del conector
# cloudflared, p.ej. 127.0.0.1. Default VACIO = no confiar
# ningun proxy = se usa el peer host (comportamiento actual, cero riesgo).
# CAVEAT ANTI-SPOOF (no negociable): la IP real se lee del header SOLO si el peer
# inmediato esta en esta allowlist. NUNCA agregues aca una IP que no controles: si el
# peer no es confiable, un atacante spoofea el header y se da una IP nueva por intento,
# evadiendo el rate-limit por completo (PEOR que el status quo).
TRUSTED_PROXY_IPS=
# REAL_IP_HEADER: header del que se lee la IP real del cliente cuando el peer es
# confiable. Cloudflare Tunnel manda CF-Connecting-IP.
REAL_IP_HEADER=CF-Connecting-IP

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ynara-uploads

# Observabilidad
# Sentry: vacio => deshabilitado (no se manda nada a ningun lado). Con DSN, el
# before_send limpia PII antes de transmitir (regla #4). traces 0.0 = sin tracing.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# CORS — origins permitidos por el navegador (issue #212). Formato CSV
# human-friendly: una o varias URLs separadas por comas (sin JSON), p.ej.
# CORS_ORIGINS=https://app.ynara.com,https://api.ynara.com
# Default DEV (si se omite la var): http://localhost:3000,http://localhost:8081.
# STAGING: dominios reales de staging (SIN localhost), p.ej.
#   CORS_ORIGINS=https://staging.ynara.com,https://staging-api.ynara.com
# PRODUCTION: dominios reales del front web + el origin del deep-link mobile
#   (placeholder hasta fijar el valor de deploy):
#   CORS_ORIGINS=https://<web-domain>,https://<mobile-deep-link-origin>
# FAIL-FAST: en ENVIRONMENT=production el boot ABORTA si queda algun origin de
# dev (localhost/127.0.0.1/::1) -> hay que fijar dominios reales (config.py
# _reject_dev_config_in_prod). En dev se deja vacio/omitido para usar el default.
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Panel admin interno (/v1/admin/*). CSV human-friendly de UUIDs de usuarios que
# arrancan como admin ANTES de que la columna users.is_admin este poblada
# (bootstrap, huevo-y-la-gallina). get_current_admin gatea contra
# user.is_admin OR str(user_id) in ADMIN_BOOTSTRAP_IDS. Default VACIO = nadie es
# admin por bootstrap (solo quienes tengan la flag en DB). Ej:
# ADMIN_BOOTSTRAP_IDS=11111111-1111-1111-1111-111111111111,22222222-2222-2222-2222-222222222222
ADMIN_BOOTSTRAP_IDS=

# Conexión / Compartir (panel admin, /v1/admin/connectivity). Puertos de los
# servicios que el panel expone para compartir con otra máquina por el tailnet de
# Tailscale: Ollama (API OpenAI-compatible) y Open WebUI (chat). Defaults Ollama
# 11434 / Open WebUI 3001; cambialos solo si corrés esos servicios en otro puerto.
OLLAMA_API_PORT=11434
OPENWEBUI_PORT=3001

# Environment
ENVIRONMENT=development
