# Base de datos (Fase MVP: Supabase como Postgres gestionado)
# En V2 se cambia este connection string al Postgres self-hosted
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Pool de conexiones (Supabase recomienda 15 max para free tier)
DATABASE_POOL_SIZE=10

# Redis (Upstash free tier o local en Docker)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# Endpoints LLM (vLLM corriendo en la 4080 Super)
GEMMA_ENDPOINT=http://localhost:8000/v1
QWEN_ENDPOINT=http://localhost:8001/v1

# Embeddings
EMBEDDING_MODEL=bge-m3

# Auth
JWT_SECRET=cambiar-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ynara-uploads

# Observabilidad
SENTRY_DSN=
POSTHOG_KEY=

# Environment
ENVIRONMENT=development
