# apps/mobile — Variables de entorno

# URL pública del backend FastAPI.
# OJO en dispositivo real: el celu NO resuelve el localhost de tu PC.
# Usá la IP de tu PC en la LAN, p. ej. EXPO_PUBLIC_API_URL=http://192.168.1.8:8080
# (localhost solo sirve en simulador/web).
EXPO_PUBLIC_API_URL=http://localhost:8080

# Telemetría (opcional)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_SENTRY_DSN=

# TODO: agregar otras variables del cliente con prefijo EXPO_PUBLIC_.
# Variables sin ese prefijo solo están disponibles en build time.

# Recordatorio: prohibido @supabase/supabase-js desde el cliente
# (regla #5 de AGENTS.md). Todo acceso a datos va por
# EXPO_PUBLIC_API_URL.
