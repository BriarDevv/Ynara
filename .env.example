# .env.example raíz — variables globales del monorepo
# Cada app tiene su propio .env.example con variables específicas:
# - apps/web/.env.example
# - apps/mobile/.env.example
# - apps/backend/.env.example

# Modo global
NODE_ENV=development
ENVIRONMENT=development

# Telemetría opcional (Turborepo Remote Cache)
TURBO_TEAM=
TURBO_TOKEN=

# TODO: agregar otras variables globales si aparecen
